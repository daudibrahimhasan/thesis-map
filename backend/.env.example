PORT=4000
DB_PATH=./data/thesismatch.sqlite
ADMIN_API_KEY=change-me
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://your-production-domain.com
DEFAULT_DEPARTMENT=CSE

# Supabase (Optional)
# If provided, the app will switch from SQLite to Supabase Postgres
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_KEY=your-service-key (Optional, for admin bypass)
